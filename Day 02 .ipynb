    "**4. Calculate the total revenue per product**\n",
    "\n",
    "SELECT product_id,\n",
    "SUM (quantity * price) AS\n",
    "total_revenue\n",
    "FROM Sales\n",
    "GROUP BY product_id;"
   ]
  }
