   "source": [
    "01 **Find employees without department (Left Join usage)**\n",
    "\n",
    "\n",
    "SELECT e.*\n",
    "FROM Employee e\n",
    "LEFT JOIN Department d\n",
    "ON e. department_id = d. department_id\n",
    "WHERE d.department_id IS NULL;"
   ]
  }
